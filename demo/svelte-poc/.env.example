# --- Server-only (never shipped to the browser) -----------------------------
# FUNK radio control-plane base URL. The server proxy calls
# $FUNK_RADIO_URL/v1/radio/now-playing.
FUNK_RADIO_URL=http://localhost:7403

# FUNK storage base URL. The admin upload form POSTs MP3s to
# $FUNK_STORAGE_URL/uploads, then schedules them via the returned
# $FUNK_STORAGE_URL/files/<key> stable URL. Must be reachable by the media
# plane's liquidsoap (it fetches the file to broadcast it).
FUNK_STORAGE_URL=http://localhost:7402

# Service credential minted against FUNK's auth bootstrap. Sent as
# `Authorization: Bearer <token>` on every control-plane call. STAYS SERVER-SIDE.
# Mint one with:
#   curl -s -X POST http://localhost:7401/v1/credentials \
#     -H "authorization: Bearer dev_admin_bootstrap_change_me" \
#     -H "content-type: application/json" \
#     -d '{"label":"demo-poc"}'
# then copy the returned "token" value here.
FUNK_SERVICE_TOKEN=<mint-me>

# --- Admin auth (server-only, never shipped to the browser) -----------------
# Hardcoded operator credentials for the /admin programming screen. There is no
# user DB in the demo, so these live in env and are compared SERVER-SIDE only —
# the password never reaches the client (same discipline as FUNK_SERVICE_TOKEN).
DEMO_ADMIN_USER=admin
DEMO_ADMIN_PASS=funkdemo

# Optional: secret used to sign the httpOnly admin session cookie. If unset, a
# secret is derived from DEMO_ADMIN_PASS so the demo works with zero extra
# config. Set an explicit value in any shared/long-lived deployment.
# DEMO_SESSION_SECRET=change-me-to-a-long-random-string

# --- Public (shipped to the browser) ----------------------------------------
# The anonymous HLS master playlist. The browser's hls.js hits this directly —
# no token, no proxy.
PUBLIC_FUNK_HLS_URL=http://localhost:7488/hls/master.m3u8
