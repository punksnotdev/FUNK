NODE_ENV=development

# Icecast (internal passwords; rotate for staging/prod)
ICECAST_SOURCE_PASSWORD=devsource_change_me
ICECAST_ADMIN_PASSWORD=devadmin_change_me
ICECAST_RELAY_PASSWORD=devrelay_change_me
ICECAST_HOST_PORT=8000

# HLS generator pulls from icecast over the internal network
ICECAST_SOURCE_URL=http://icecast:8000/funk.mp3
SEGMENT_SECONDS=6
PLAYLIST_SIZE=6
FFMPEG_LOGLEVEL=warning

# Nginx HLS origin
HLS_ORIGIN_HOST_PORT=8080

# LibreTime (opt-in — set up via scripts/libretime-setup.sh which fills these in)
LIBRETIME_VERSION=4.5.0
# LIBRETIME_POSTGRES_PASSWORD=<generated>
# LIBRETIME_RABBITMQ_PASSWORD=<generated>
# LIBRETIME_API_KEY=<generated>
# LIBRETIME_SECRET_KEY=<generated>
LIBRETIME_PUBLIC_URL=http://localhost:8090
LIBRETIME_TIMEZONE=UTC
LIBRETIME_NGINX_HOST_PORT=8090
