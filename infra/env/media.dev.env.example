NODE_ENV=development

# Icecast (internal passwords; rotate for staging/prod)
ICECAST_SOURCE_PASSWORD=devsource_change_me
ICECAST_ADMIN_PASSWORD=devadmin_change_me
ICECAST_RELAY_PASSWORD=devrelay_change_me
ICECAST_HOST_PORT=8000

# HLS generator pulls from icecast over the internal network
ICECAST_SOURCE_URL=http://icecast:8000/funk.mp3
SEGMENT_SECONDS=6
PLAYLIST_SIZE=6
FFMPEG_LOGLEVEL=warning

# Nginx HLS origin
HLS_ORIGIN_HOST_PORT=8080

# Liquidsoap harbor mounts (live transmissions and breaking-news takeover).
# Per-host credentials are minted via POST /v1/radio/live/credentials.
# RADIO_INTERNAL_SECRET guards the internal endpoints that liquidsoap calls.
RADIO_INTERNAL_SECRET=dev_internal_secret_change_me
HARBOR_LIVE_HOST_PORT=8001
HARBOR_BREAKING_HOST_PORT=8002
LIQUIDSOAP_TELNET_HOST_PORT=1234

# Radio control API
RADIO_PORT=4003
RADIO_HOST_PORT=4003
# How radio (on the media plane) reaches the control plane's auth service.
# In dev, both planes attach to the shared `funk_dev` network and resolve
# auth by DNS alias. See LOCAL_DEV.md for the one-time setup.
AUTH_URL=http://auth:4001
