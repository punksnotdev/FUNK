NODE_ENV=development

# Icecast (internal passwords; rotate for staging/prod)
ICECAST_SOURCE_PASSWORD=devsource_change_me
ICECAST_ADMIN_PASSWORD=devadmin_change_me
ICECAST_RELAY_PASSWORD=devrelay_change_me
ICECAST_HOST_PORT=8000

# HLS generator pulls from icecast over the internal network
ICECAST_SOURCE_URL=http://icecast:8000/funk.mp3
SEGMENT_SECONDS=6
PLAYLIST_SIZE=6
FFMPEG_LOGLEVEL=warning

# Nginx HLS origin
HLS_ORIGIN_HOST_PORT=8080

# Liquidsoap harbor mounts (live transmissions and breaking-news takeover).
# In v0 a single shared password per mount; per-host credentials are rotated by
# funk-radio at runtime in a later iteration.
HARBOR_LIVE_PASSWORD=devlive_change_me
HARBOR_BREAKING_PASSWORD=devbreaking_change_me
HARBOR_LIVE_HOST_PORT=8001
HARBOR_BREAKING_HOST_PORT=8002
LIQUIDSOAP_TELNET_HOST_PORT=1234

# Radio control API
RADIO_PORT=4003
RADIO_HOST_PORT=4003
# How radio (on the media plane) reaches the control plane's auth service.
# In dev, both planes attach to the shared `funk_dev` network and resolve
# auth by DNS alias. See LOCAL_DEV.md for the one-time setup.
AUTH_URL=http://auth:4001
# Shared secret for internal radio endpoints (harbor-auth, disconnect,
# recording-attribution). Set the same value in the media plane .env.
# Generate with: openssl rand -hex 32
RADIO_INTERNAL_SECRET=dev_radio_internal_secret_change_me

# Recordings upload daemon
RECORDINGS_PORT=4004
RECORDINGS_HOST_PORT=4004
# How the recordings daemon reaches FUNK storage (cross-plane via funk_dev in dev).
STORAGE_URL=http://storage:4002
# How many seconds a file's mtime must be stable before upload (default 30).
STABILITY_SECONDS=30
# ADMIN_BOOTSTRAP_TOKEN is used by the recordings daemon to mint its own
# storage credential at startup. In dev this must match control.dev.env.
ADMIN_BOOTSTRAP_TOKEN=dev_admin_bootstrap_change_me
