NODE_ENV=development

# Icecast (internal passwords; rotate for staging/prod)
ICECAST_SOURCE_PASSWORD=devsource_change_me
ICECAST_ADMIN_PASSWORD=devadmin_change_me
ICECAST_RELAY_PASSWORD=devrelay_change_me
ICECAST_HOST_PORT=7480

# HLS generator pulls from icecast over the internal network
ICECAST_SOURCE_URL=http://icecast:8000/funk.mp3
SEGMENT_SECONDS=6
PLAYLIST_SIZE=6
FFMPEG_LOGLEVEL=warning

# Nginx HLS origin
HLS_ORIGIN_HOST_PORT=7488

# Liquidsoap harbor mounts (live transmissions and breaking-news takeover).
# Per-host credentials are minted via POST /v1/radio/live/credentials.
# RADIO_INTERNAL_SECRET guards the internal endpoints that liquidsoap calls.
RADIO_INTERNAL_SECRET=dev_internal_secret_change_me
HARBOR_LIVE_HOST_PORT=7481
HARBOR_BREAKING_HOST_PORT=7482
LIQUIDSOAP_TELNET_HOST_PORT=7423

# Radio control API (internal port stays 4003; host-published on 74xx)
RADIO_PORT=4003
RADIO_HOST_PORT=7403
# How radio (on the media plane) reaches the control plane's auth service.
# In dev, both planes attach to the shared `funk_dev` network and resolve
# auth by DNS alias. See LOCAL_DEV.md for the one-time setup.
AUTH_URL=http://auth:4001

# Recordings upload daemon (internal 4004; host-published on 74xx)
RECORDINGS_PORT=4004
RECORDINGS_HOST_PORT=7404
# Recordings daemon reaches control-plane services by DNS name on the
# shared funk_dev bridge (same approach radio uses for AUTH_URL).
RECORDINGS_AUTH_URL=http://auth:4001
STORAGE_URL=http://storage:4002
# Public-facing storage URL embedded in /v1/radio/recordings → storage_url.
# In dev this must be reachable from the host (browsers, smoke test, etc.),
# so we use the host-mapped port. In prod set to the public HTTPS URL.
STORAGE_PUBLIC_URL=http://localhost:7402
# How many seconds a file's mtime must be stable before upload (default 30).
STABILITY_SECONDS=30
# ADMIN_BOOTSTRAP_TOKEN is used by the recordings daemon to mint its own
# storage credential at startup. In dev this must match control.dev.env.
ADMIN_BOOTSTRAP_TOKEN=dev_admin_bootstrap_change_me
