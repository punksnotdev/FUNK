NODE_ENV=development

# Postgres
POSTGRES_DB=funk
POSTGRES_USER=funk
POSTGRES_PASSWORD=devpassword_change_me
POSTGRES_HOST_PORT=5432

# MinIO
MINIO_ROOT_USER=funkadmin
MINIO_ROOT_PASSWORD=devpassword_change_me
MINIO_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
S3_BUCKET=funk-uploads
S3_REGION=us-east-1
# What clients see in presigned URLs; in dev MinIO is exposed on host:9000.
S3_PUBLIC_ENDPOINT=http://localhost:9000

# Auth service
AUTH_PORT=4001
AUTH_HOST_PORT=4001
TENANT_ID=default
ADMIN_BOOTSTRAP_TOKEN=dev_admin_bootstrap_change_me
SESSION_TTL_HOURS=720

# Storage service
STORAGE_PORT=4002
STORAGE_HOST_PORT=4002
MAX_UPLOAD_BYTES=104857600
