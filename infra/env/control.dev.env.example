NODE_ENV=development

# Postgres
POSTGRES_DB=funk
POSTGRES_USER=funk
POSTGRES_PASSWORD=devpassword_change_me
POSTGRES_HOST_PORT=7432

# MinIO
MINIO_ROOT_USER=funkadmin
MINIO_ROOT_PASSWORD=devpassword_change_me
MINIO_HOST_PORT=7490
MINIO_CONSOLE_HOST_PORT=7491
S3_BUCKET=funk-uploads
S3_REGION=us-east-1
# What clients see in presigned URLs; in dev MinIO is exposed on host:7490.
S3_PUBLIC_ENDPOINT=http://localhost:7490

# Auth service (internal port stays 4001; host-published on the reserved 74xx band)
AUTH_PORT=4001
AUTH_HOST_PORT=7401
TENANT_ID=default
ADMIN_BOOTSTRAP_TOKEN=dev_admin_bootstrap_change_me

# Storage service (internal 4002; host-published on 74xx)
STORAGE_PORT=4002
STORAGE_HOST_PORT=7402
MAX_UPLOAD_BYTES=104857600
