NODE_ENV=production

ICECAST_SOURCE_PASSWORD=__SET_VIA_SECRETS__
ICECAST_ADMIN_PASSWORD=__SET_VIA_SECRETS__
ICECAST_RELAY_PASSWORD=__SET_VIA_SECRETS__

ICECAST_SOURCE_URL=http://icecast:8000/funk.mp3
SEGMENT_SECONDS=6
PLAYLIST_SIZE=6
FFMPEG_LOGLEVEL=warning

# Internal secret for liquidsoap → radio harbor-auth callbacks.
# Must match RADIO_INTERNAL_SECRET in radio's env. Never exposed publicly.
RADIO_INTERNAL_SECRET=__SET_VIA_SECRETS__

# Radio control API
RADIO_PORT=4003
# Public HTTPS URL of the control-plane auth service.
AUTH_URL=https://auth.funk.example
# ADR-004 Amendment: harbor credentials + sessions live in the control-plane
# auth service (the media plane is fully stateless). radio sends this shared
# secret to auth's internal harbor endpoints. Must match AUTH_INTERNAL_SECRET
# in the control-plane env. Never exposed publicly.
AUTH_INTERNAL_SECRET=__SET_VIA_SECRETS__

# Recordings: control-plane storage service. Radio lists the `recordings/`
# prefix to answer GET /v1/radio/recordings (ADR-004 Slice 3); the recordings
# daemon uploads here. STORAGE_PUBLIC_URL is the host baked into each recording's
# storage_url (must be reachable by the consumer). ADMIN_BOOTSTRAP_TOKEN mints
# the service credentials radio + the daemon use against the control plane.
RECORDINGS_PORT=4004
RECORDINGS_AUTH_URL=https://auth.funk.example
STORAGE_URL=https://storage.funk.example
STORAGE_PUBLIC_URL=https://storage.funk.example
STABILITY_SECONDS=30
ADMIN_BOOTSTRAP_TOKEN=__SET_VIA_SECRETS__

# Edge (with-edge profile)
CADDY_ADMIN_EMAIL=ops@example.org
ORIGIN_PUBLIC_HOSTNAME=stream.funk.example
