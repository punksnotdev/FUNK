NODE_ENV=production

ICECAST_SOURCE_PASSWORD=__SET_VIA_SECRETS__
ICECAST_ADMIN_PASSWORD=__SET_VIA_SECRETS__
ICECAST_RELAY_PASSWORD=__SET_VIA_SECRETS__

ICECAST_SOURCE_URL=http://icecast:8000/funk.mp3
SEGMENT_SECONDS=6
PLAYLIST_SIZE=6
FFMPEG_LOGLEVEL=warning

# Edge (with-edge profile)
CADDY_ADMIN_EMAIL=ops@example.org
ORIGIN_PUBLIC_HOSTNAME=stream.funk.example

# LibreTime
LIBRETIME_VERSION=4.5.0
LIBRETIME_POSTGRES_PASSWORD=__SET_VIA_SECRETS__
LIBRETIME_RABBITMQ_PASSWORD=__SET_VIA_SECRETS__
LIBRETIME_API_KEY=__SET_VIA_SECRETS__
LIBRETIME_SECRET_KEY=__SET_VIA_SECRETS__
LIBRETIME_PUBLIC_URL=https://libretime.funk.example
LIBRETIME_TIMEZONE=UTC
