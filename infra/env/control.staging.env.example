NODE_ENV=production

# Postgres
POSTGRES_DB=funk
POSTGRES_USER=funk
POSTGRES_PASSWORD=__SET_VIA_SECRETS__

# MinIO
MINIO_ROOT_USER=funkadmin
MINIO_ROOT_PASSWORD=__SET_VIA_SECRETS__
S3_BUCKET=funk-uploads
S3_REGION=us-east-1
# Externally-reachable URL for presigned downloads. Typically Caddy → MinIO,
# or a separate S3-compatible CDN edge.
S3_PUBLIC_ENDPOINT=https://files.staging.funk.example

# Auth service
AUTH_PORT=4001
TENANT_ID=default
ADMIN_BOOTSTRAP_TOKEN=__SET_VIA_SECRETS__

# Storage service
STORAGE_PORT=4002
MAX_UPLOAD_BYTES=104857600

# Edge (with-edge profile)
CADDY_ADMIN_EMAIL=ops@example.org
AUTH_PUBLIC_HOSTNAME=auth.staging.funk.example
STORAGE_PUBLIC_HOSTNAME=storage.staging.funk.example
